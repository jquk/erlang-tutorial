# Compiled Erlang files.
# These are the compiled bytecode files generated by the Erlang compiler, e.g. (c(demo).).
*.beam

# Crash dumps.
# Created automatically when the Erlang runtime environment crashes.
erl_crash.dump

# Rebar3 build directories (if you use rebar3 later).
# The standard output folder for Rebar3, the official Erlang build tool.
_build/
.rebar3/

# Hex package manager cache
.hex/

